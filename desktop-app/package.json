{
  "name": "burnout-detector-desktop",
  "version": "1.0.0",
  "description": "Desktop monitoring agent for Burnout Detector",
  "main": "main.js",
  "author": "Burnout Detector Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build": "electron-builder -mwl",
    "dev": "electron . --verbose",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "iohook": "^0.9.3",
    "python-shell": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^latest",
    "electron-builder": "^24.0.0",
    "electron-is-dev": "^2.0.0"
  },
  "build": {
    "appId": "com.burnoutdetector.desktop",
    "productName": "Burnout Detector",
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
