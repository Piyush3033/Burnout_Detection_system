# Vercel (Frontend) — use = not : between key and value
BACKEND_URL=https://burnout-detection-system.onrender.com
NEXT_PUBLIC_BACKEND_URL=https://burnout-detection-system.onrender.com
NEXT_PUBLIC_ML_URL=https://ml-service-1nhu.onrender.com

# Render (Backend - server/)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/burnout
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRY=7d
CORS_ORIGIN=https://your-app.vercel.app
ML_SERVICE_URL=https://your-ml-service.onrender.com
PORT=5000

# Render (ML Service - ml-service/)
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/burnout
TIMEZONE=UTC

# Desktop Agent (desktop-agent/.env)
API_URL=https://your-burnout-backend.onrender.com
USER_TOKEN=your-jwt-from-login
COLLECTION_INTERVAL_SECONDS=5
